# Audit Service environment configuration
# Copy to .env for local dev; on Railway, set these via the dashboard.

# Shared secret with dispatch — MUST be identical on both Railway projects
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
AUDIT_SERVICE_JWT_SECRET=change-me-to-a-long-random-string

# Port (Railway injects this automatically; only set locally)
PORT=8000

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Max processing time per audit in seconds (contract §4.1 = 120s hard limit)
MAX_PROCESSING_SECONDS=120

# Max concurrent audits (contract §9 rate limit = 10/min)
MAX_CONCURRENT_AUDITS=3
